{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 25, "patch": 0 },

  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },

    {
      "name": "base-clang",
      "hidden": true,
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_C_COMPILER":   "clang",
        "CMAKE_CXX_COMPILER": "clang++"
      }
    },

    {
      "name": "base-msvc",
      "hidden": true,
      "generator": "Visual Studio 17 2022",
      "architecture": {
        "value": "x64",
        "strategy": "set"
      },
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },

    {
      "name": "debug",
      "displayName": "Debug (Linux/macOS — ASan + UBSan)",
      "inherits": "base-clang",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "ENABLE_ASAN":      "ON",
        "ENABLE_UBSAN":     "ON"
      },
      "condition": {
        "type": "notEquals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },

    {
      "name": "debug-win",
      "displayName": "Debug (Windows — ASan via MSVC)",
      "inherits": "base-msvc",
      "cacheVariables": {
        "ENABLE_ASAN":      "ON"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },

    {
      "name": "release",
      "displayName": "Release",
      "inherits": "base-clang",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      },
      "condition": {
        "type": "notEquals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },

    {
      "name": "release-win",
      "displayName": "Release (Windows)",
      "inherits": "base-msvc",
      "cacheVariables": {},
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },

    {
      "name": "relwithdebinfo",
      "displayName": "RelWithDebInfo",
      "inherits": "base-clang",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      },
      "condition": {
        "type": "notEquals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },

    {
      "name": "relwithdebinfo-win",
      "displayName": "RelWithDebInfo (Windows)",
      "inherits": "base-msvc",
      "cacheVariables": {},
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    }
  ],

  "buildPresets": [
    { "name": "debug",             "configurePreset": "debug" },
    { "name": "debug-win",         "configurePreset": "debug-win",         "configuration": "Debug" },
    { "name": "release",           "configurePreset": "release" },
    { "name": "release-win",       "configurePreset": "release-win",       "configuration": "Release" },
    { "name": "relwithdebinfo",    "configurePreset": "relwithdebinfo" },
    { "name": "relwithdebinfo-win","configurePreset": "relwithdebinfo-win", "configuration": "RelWithDebInfo" }
  ]
}
