# Doxyfile.in — filled in by CMake (cmake/Doxygen.cmake)
PROJECT_NAME        = "@PROJECT_NAME@"
PROJECT_BRIEF       = "@PROJECT_DESCRIPTION@"
PROJECT_NUMBER      = "@PROJECT_VERSION@"

INPUT               = "@CMAKE_SOURCE_DIR@/src"
RECURSIVE           = YES
FILE_PATTERNS       = *.cpp *.hpp *.h
EXCLUDE_PATTERNS    = */build/* */_deps/* */cmake-build-*/*

OUTPUT_DIRECTORY    = "@DOXYGEN_OUTPUT_DIR@"
HTML_OUTPUT         = html
GENERATE_HTML       = YES
GENERATE_LATEX      = NO

GENERATE_TREEVIEW   = YES
DISABLE_INDEX       = NO

EXTRACT_ALL         = YES
EXTRACT_PRIVATE     = NO
EXTRACT_STATIC      = YES

JAVADOC_AUTOBRIEF   = YES
QT_AUTOBRIEF        = NO

WARN_IF_UNDOCUMENTED    = NO
WARN_IF_DOC_ERROR       = YES
WARN_NO_PARAMDOC        = NO

# ---------------------------------------------------------------------------
# Diagrams (requires Graphviz — cmake/Doxygen.cmake sets HAVE_DOT automatically)
# ---------------------------------------------------------------------------
HAVE_DOT            = @DOXYGEN_HAVE_DOT@
DOT_PATH            = @DOXYGEN_DOT_PATH@

# Use SVG so diagrams are sharp at any zoom level and are interactive.
DOT_IMAGE_FORMAT    = svg
INTERACTIVE_SVG     = YES

# Which diagrams to generate:
INCLUDE_GRAPH       = YES   # which headers each file includes
INCLUDED_BY_GRAPH   = YES   # reverse: who includes this file
CALL_GRAPH          = YES   # functions called by each function
CALLER_GRAPH        = YES   # functions that call each function
CLASS_GRAPH         = YES   # inheritance / struct relationships
COLLABORATION_GRAPH = YES   # what types each class uses
DIRECTORY_GRAPH     = YES   # directory-level dependency overview

# Cap diagram complexity so they stay readable.
DOT_GRAPH_MAX_NODES = 50

QUIET               = NO
