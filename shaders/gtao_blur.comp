/// @file gtao_blur.comp
/// @brief Cross-bilateral blur for GTAO.
/// Edge-preserving spatial filter: uses depth similarity to weight samples,
/// preventing AO from bleeding across geometry edges.
#version 450

layout(local_size_x = 16, local_size_y = 16, local_size_z = 1) in;

/// @brief Input AO texture from GTAO pass.
layout(set = 0, binding = 0) uniform sampler2D aoInput;
/// @brief Scene depth texture for edge detection.
layout(set = 0, binding = 1) uniform sampler2D depthTexture;
/// @brief Output blurred AO image.
layout(set = 1, binding = 0, r8) writeonly uniform image2D aoOutput;

/// @brief Bilateral blur parameters.
layout(set = 2, binding = 0) uniform BlurParams {
    vec2 screenSize;
    float depthSigma;    // depth similarity threshold
    float _pad;
};

void main()
{
    ivec2 coord = ivec2(gl_GlobalInvocationID.xy);
    ivec2 size = imageSize(aoOutput);
    if (coord.x >= size.x || coord.y >= size.y) return;

    vec2 uv = (vec2(coord) + 0.5) / vec2(size);
    vec2 ts = 1.0 / screenSize;

    float centerAO = texture(aoInput, uv).r;
    float centerDepth = texture(depthTexture, uv).r;

    // Sky -> pass through.
    if (centerDepth >= 0.9999) {
        imageStore(aoOutput, coord, vec4(1.0));
        return;
    }

    // Linearize depth for better edge detection.
    // Approximate linear depth from NDC depth.
    float centerLinear = 1.0 / max(centerDepth, 0.0001);

    float totalAO = 0.0;
    float totalWeight = 0.0;

    // 7x7 bilateral kernel.
    const int RADIUS = 3;
    // Spatial Gaussian weights for radius=3 (sigma ~ 1.5).
    const float spatialWeights[4] = float[](1.0, 0.7788, 0.3679, 0.1054);

    for (int y = -RADIUS; y <= RADIUS; ++y) {
        for (int x = -RADIUS; x <= RADIUS; ++x) {
            vec2 sampleUV = uv + vec2(float(x), float(y)) * ts;

            float sampleAO = texture(aoInput, sampleUV).r;
            float sampleDepth = texture(depthTexture, sampleUV).r;

            // Spatial weight (Gaussian).
            float spatial = spatialWeights[abs(x)] * spatialWeights[abs(y)];

            // Depth-based edge weight (bilateral term).
            float sampleLinear = 1.0 / max(sampleDepth, 0.0001);
            float depthDiff = abs(centerLinear - sampleLinear);
            float depthWeight = exp(-depthDiff * depthDiff * depthSigma);

            float w = spatial * depthWeight;
            totalAO += sampleAO * w;
            totalWeight += w;
        }
    }

    float result = (totalWeight > 0.0) ? totalAO / totalWeight : centerAO;
    imageStore(aoOutput, coord, vec4(result));
}
