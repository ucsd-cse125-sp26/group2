{
  "version": "0.2.0",
  "configurations": [
    {
      // Linux / macOS — uses lldb via cpptools.
      // ${command:cmake.launchTargetPath} resolves to the selected CMake target's
      // output binary (e.g. build/debug/group2) regardless of which preset is active.
      "name": "Launch group2 (Linux / macOS)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${command:cmake.launchTargetPath}",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [
        {
          // Suppress SDL3 LSan false-positive leak reports on Linux debug builds
          "name": "LSAN_OPTIONS",
          "value": "suppressions=${workspaceFolder}/sanitizers/lsan.supp"
        }
      ],
      "MIMode": "lldb",
      "externalConsole": false,
      "preLaunchTask": "CMake: Build"
    },
    {
      // Windows — uses the Visual Studio debugger (cppvsdbg) via cpptools.
      "name": "Launch group2 (Windows)",
      "type": "cppvsdbg",
      "request": "launch",
      "program": "${command:cmake.launchTargetPath}",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": false,
      "preLaunchTask": "CMake: Build"
    }
  ]
}
